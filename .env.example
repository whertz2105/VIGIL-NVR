# ============================================================================
# nvr-viewer — example environment. Copy to `.env` and adjust.
#   cp .env.example .env
# Every value has a built-in default; set only what differs. The app also reads
# a runtime /data/settings.json (written by the Settings GUI) that overrides
# these — resolution order is: built-in default -> this env -> settings file.
# ============================================================================

# Timezone used to interpret recording folder names and label times.
TZ=UTC

# Branding shown in the header/title.
BRAND=NVR

# --- MediaMTX (your streaming server) -------------------------------------
# HTTP API of YOUR MediaMTX instance. The viewer auto-discovers cameras from it.
MEDIAMTX_API=http://mediamtx:9997
# URL prefix where the BROWSER fetches HLS (via your reverse proxy, or MediaMTX
# directly). e.g. <HLS_PREFIX>/<cam>/index.m3u8
HLS_PREFIX=/hls

# --- Storage paths (mount these as volumes) -------------------------------
# Read-only: your recorder's output. Layout: {YY_MM_DD}/{HH}/{cam}/{cam}_{HH-MM}.mp4
RECORDINGS_DIR=/recordings
# Read-only: nightly timelapse clips. Layout: {YY_MM_DD}/{cam}.mp4
TIMELAPSES_DIR=/timelapses
# Read-write: saved (flagged) alert clips.
FLAGGED_DIR=/flagged
# Read-write: cache, alert-mark state, settings.json, and admin.json (the admin
# password hash + session secret live here — keep this volume private).
CACHE_DIR=/data

# --- Admin login / sessions -----------------------------------------------
# Admin session lifetime in seconds (default 7 days). First run with no password
# set generates a random one and prints it ONCE to the container logs.
SESSION_MAX_AGE=604800

# Optional: if a reverse proxy authenticates users and passes the username in a
# header, set this to that header's name to DISPLAY it (read-only). It is NEVER
# used for authorization. Leave unset for anonymous (the default).
# TRUSTED_USER_HEADER=X-Forwarded-User

# --- Detection (optional; only if you run the Frigate companion) ----------
# HTTP API of YOUR Frigate instance. The detection/alert features simply don't
# appear if Frigate is absent.
FRIGATE_API=http://frigate:5000
# Path (inside the container) to a Frigate config file for the Settings zone/mask
# editor. If unset, the editor is hidden. The editor writes the config + a
# timestamped backup and shows "restart Frigate to apply" — it never reloads or
# restarts Frigate, and the viewer holds no Docker socket.
# FRIGATE_CONFIG=/frigate-config/config.yml

# --- Alert behaviour (also editable in the Settings GUI) ------------------
# Collapse same-camera + same-label detections within N seconds into one alert.
GROUP_GAP_SECONDS=60
# Flagged-clip window: this many seconds before and after the event.
FLAG_PRE_SECONDS=30
FLAG_POST_SECONDS=300
# "Silence alerts" snooze duration (seconds; 7200 = 2h).
MUTE_SECONDS=7200

# NOTE: alert filtering (which detections to surface) is auto-derived from your
# Frigate zone definitions — zones whose `objects` include car contribute car
# alerts, person likewise; multiple zones per type are supported; if a camera
# has no zones, all its events show. There is no manual car-zone setting.
#
# NOTE: camera RTSP credentials and any tokens belong to YOUR MediaMTX / proxy
# config, NOT here. This app holds no camera credentials.
